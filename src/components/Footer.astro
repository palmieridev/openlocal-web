---
import { Icon } from "astro-icon/components";

const year = new Date().getFullYear();
const cols = [
  {
    title: "Explorar",
    links: [
      { href: "/marketplace", label: "Marketplace" },
      { href: "/marketplace?map=1", label: "Mapa" },
      { href: "/marketplace?filter=handmade", label: "Hecho a mano" },
    ],
  },
  {
    title: "Para negocios",
    links: [
      { href: "/register", label: "Vender en Openlocal" },
      { href: "/dashboard", label: "Panel de control" },
      { href: "/login", label: "Iniciar sesión" },
    ],
  },
  {
    title: "Proyecto",
    links: [
      { href: "https://github.com/palmieridev/openlocal-api", label: "Código abierto" },
      { href: "/", label: "Acerca de" },
    ],
  },
];
---

<footer class="mt-16 border-t border-border bg-surface-secondary">
  <div class="mx-auto grid max-w-7xl gap-8 px-4 py-12 sm:px-6 md:grid-cols-[1.5fr_repeat(3,1fr)]">
    <div class="flex flex-col gap-3">
      <a href="/" class="flex items-center gap-2">
        <span class="flex size-8 items-center justify-center rounded-lg bg-accent">
          <Icon name="lucide:store" class="text-text-inverse" width={18} height={18} />
        </span>
        <span class="font-heading text-lg font-semibold">OpenLocal</span>
      </a>
      <p class="max-w-xs text-sm text-text-secondary">
        Hub de comercio local de código abierto: inventario, tiendas y
        descubrimiento de productos cerca de ti.
      </p>
    </div>

    {cols.map((col) => (
      <div class="flex flex-col gap-3">
        <h4 class="text-xs font-semibold uppercase tracking-wide text-text-muted">{col.title}</h4>
        <ul class="flex flex-col gap-2">
          {col.links.map((l) => (
            <li>
              <a href={l.href} class="text-sm text-text-secondary hover:text-text-primary">
                {l.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>

  <div class="border-t border-border">
    <div class="mx-auto max-w-7xl px-4 py-5 text-xs text-text-muted sm:px-6">
      © {year} Openlocal · Hecho para negocios locales en México 🇲🇽
    </div>
  </div>
</footer>
