---
import { Icon } from "astro-icon/components";
import { Show, UserButton } from "@clerk/astro/components";
import Button from "@/components/ui/Button.astro";

const path = Astro.url.pathname;
const links = [
  { href: "/", label: "Inicio" },
  { href: "/marketplace", label: "Marketplace" },
];
const isActive = (href: string) =>
  href === "/" ? path === "/" : path.startsWith(href);
---

<header class="sticky top-0 z-40 border-b border-border bg-surface-primary/85 backdrop-blur">
  <div class="mx-auto flex h-16 max-w-7xl items-center gap-6 px-4 sm:px-6">
    <a href="/" class="flex items-center gap-2">
      <span class="flex size-8 items-center justify-center rounded-lg bg-accent">
        <Icon name="lucide:store" class="text-text-inverse" width={18} height={18} />
      </span>
      <span class="font-heading text-lg font-semibold tracking-tight">OpenLocal</span>
    </a>

    <nav class="hidden items-center gap-1 md:flex">
      {links.map((l) => (
        <a
          href={l.href}
          class:list={[
            "rounded-full px-3 py-1.5 text-sm font-medium transition-colors",
            isActive(l.href)
              ? "bg-surface-secondary text-text-primary"
              : "text-text-secondary hover:bg-surface-secondary",
          ]}
        >
          {l.label}
        </a>
      ))}
    </nav>

    <div class="ml-auto flex items-center gap-2">
      <Show when="signed-out">
        <Button variant="ghost" size="sm" href="/login" class="hidden sm:inline-flex">
          Iniciar sesión
        </Button>
        <Button variant="primary" size="sm" href="/register" icon="lucide:store">
          Vender
        </Button>
      </Show>
      <Show when="signed-in">
        <Button variant="ghost" size="sm" href="/dashboard" class="hidden sm:inline-flex">
          Panel
        </Button>
        <UserButton />
      </Show>
    </div>
  </div>
</header>
