---
import { Icon } from "astro-icon/components";
import { UserButton } from "@clerk/astro/components";
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title?: string;
  active?: string;
}
const { title = "Panel — Openlocal", active = "inicio" } = Astro.props;

const nav = [
  { key: "inicio", label: "Inicio", icon: "lucide:layout-dashboard", href: "/dashboard" },
  { key: "productos", label: "Productos", icon: "lucide:package", href: "#" },
  { key: "inventario", label: "Inventario", icon: "lucide:boxes", href: "#" },
  { key: "analitica", label: "Analítica", icon: "lucide:chart-column", href: "#" },
  { key: "tienda", label: "Tienda pública", icon: "lucide:store", href: "#" },
  { key: "ajustes", label: "Ajustes", icon: "lucide:settings", href: "#" },
];
---

<BaseLayout title={title}>
  <div class="flex min-h-screen">
    {/* Sidebar */}
    <aside class="hidden w-60 shrink-0 flex-col bg-surface-inverse p-4 text-text-inverse md:flex">
      <a href="/" class="mb-6 flex items-center gap-2 px-2">
        <span class="flex size-8 items-center justify-center rounded-lg bg-accent">
          <Icon name="lucide:store" class="text-text-inverse" width={18} height={18} />
        </span>
        <span class="font-heading text-lg font-semibold">OpenLocal</span>
      </a>

      <nav class="flex flex-1 flex-col gap-1">
        {nav.map((n) => (
          <a
            href={n.href}
            class:list={[
              "flex items-center gap-3 rounded-xl px-3 py-2.5 text-sm font-medium transition-colors",
              n.key === active
                ? "bg-white/10 text-text-inverse"
                : "text-text-inverse/60 hover:bg-white/5 hover:text-text-inverse",
            ]}
          >
            <Icon name={n.icon} width={18} height={18} />
            {n.label}
          </a>
        ))}
      </nav>

      <div class="mt-4 flex items-center gap-3 rounded-xl bg-white/5 px-3 py-2.5">
        <UserButton />
        <span class="text-sm text-text-inverse/70">Mi cuenta</span>
      </div>
    </aside>

    {/* Content */}
    <div class="flex-1 bg-surface-primary">
      <slot />
    </div>
  </div>
</BaseLayout>
