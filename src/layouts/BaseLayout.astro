---
import "@/styles/global.css";

interface Props {
  title?: string;
  description?: string;
  /** Add a class to <body> (e.g. to switch background per page). */
  bodyClass?: string;
}

const {
  title = "Openlocal — Comercio local",
  description = "Descubre productos de negocios locales cerca de ti.",
  bodyClass = "",
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="generator" content={Astro.generator} />
  </head>
  <body class={`min-h-screen bg-surface-primary text-text-primary ${bodyClass}`}>
    <slot />
  </body>
</html>
