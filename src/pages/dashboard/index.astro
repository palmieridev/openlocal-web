---
import { Icon } from "astro-icon/components";
import DashboardLayout from "@/layouts/DashboardLayout.astro";
import StatTile from "@/components/ui/StatTile.astro";
import Button from "@/components/ui/Button.astro";

// Inventory data is business-scoped and requires an active Clerk org token.
// Wired in a later milestone; tiles render placeholders for now.
const stats = [
  { label: "Valor de inventario", value: "—", icon: "lucide:package" },
  { label: "Productos activos", value: "—", icon: "lucide:tag" },
  { label: "Bajo stock", value: "—", icon: "lucide:triangle-alert" },
  { label: "Movimientos hoy", value: "—", icon: "lucide:arrow-left-right" },
];

const soon = [
  { title: "Productos", desc: "Crea productos, variantes, códigos y precios.", icon: "lucide:package" },
  { title: "Inventario", desc: "Entradas, salidas y escáner de código de barras.", icon: "lucide:scan-barcode" },
  { title: "Analítica", desc: "ABC, Pareto, EOQ y punto de reorden.", icon: "lucide:chart-column" },
];
---

<DashboardLayout active="inicio">
  <div class="mx-auto max-w-6xl px-6 py-8">
    <div class="flex flex-wrap items-center justify-between gap-3">
      <div>
        <h1 class="font-heading text-2xl font-semibold">Hola 👋</h1>
        <p class="mt-1 text-sm text-text-secondary">Resumen de tu negocio.</p>
      </div>
      <div class="flex gap-2">
        <Button variant="secondary" size="sm" icon="lucide:scan-barcode">Escanear</Button>
        <Button variant="primary" size="sm" icon="lucide:plus">Nuevo producto</Button>
      </div>
    </div>

    <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {stats.map((s) => <StatTile label={s.label} value={s.value} icon={s.icon} />)}
    </div>

    <div class="mt-8 grid gap-4 md:grid-cols-3">
      {soon.map((c) => (
        <div class="flex flex-col gap-2 rounded-2xl border border-border bg-surface-card p-5">
          <span class="flex size-9 items-center justify-center rounded-lg bg-accent-soft">
            <Icon name={c.icon} class="text-accent" width={18} height={18} />
          </span>
          <h3 class="mt-1 font-heading font-semibold">{c.title}</h3>
          <p class="text-[13px] text-text-secondary">{c.desc}</p>
          <span class="mt-1 inline-flex w-fit rounded-full bg-surface-secondary px-2.5 py-1 text-[11px] font-semibold text-text-muted">
            Próximamente
          </span>
        </div>
      ))}
    </div>
  </div>
</DashboardLayout>
