---
import { Icon } from "astro-icon/components";
import PublicLayout from "@/layouts/PublicLayout.astro";
import Button from "@/components/ui/Button.astro";
import BusinessCard from "@/components/ui/BusinessCard.astro";
import ProductCard from "@/components/ui/ProductCard.astro";
import { publicApi } from "@/lib/api/client";
import { text, humanize } from "@/lib/format";

const [businesses, products] = await Promise.all([
  publicApi.listBusinesses({ limit: 6 }),
  publicApi.searchProducts({ limit: 8 }),
]);

const categories = [
  { label: "Hecho a mano", icon: "lucide:hand", q: "handmade" },
  { label: "Comida", icon: "lucide:utensils", q: "comida" },
  { label: "Hogar", icon: "lucide:lamp", q: "hogar" },
  { label: "Moda", icon: "lucide:shirt", q: "moda" },
  { label: "Belleza", icon: "lucide:sparkles", q: "belleza" },
  { label: "Plantas", icon: "lucide:flower-2", q: "plantas" },
];

const stats = [
  { value: products.length ? `${products.length}+` : "—", label: "productos" },
  { value: businesses.length ? `${businesses.length}+` : "—", label: "negocios" },
  { value: `${categories.length}`, label: "categorías" },
];
---

<PublicLayout
  title="Openlocal — Descubre negocios locales"
  description="Encuentra productos de negocios locales cerca de ti y apoya el comercio de tu colonia."
>
  <div class="mx-auto max-w-7xl px-4 py-6 sm:px-6">
    {/* Hero */}
    <section class="grid overflow-hidden rounded-2xl bg-surface-inverse text-text-inverse md:grid-cols-[1.4fr_1fr]">
      <div class="flex flex-col justify-center gap-6 p-8 sm:p-12">
        <h1 class="font-heading text-3xl font-semibold leading-[1.1] sm:text-[42px]">
          Descubre productos de negocios locales cerca de ti
        </h1>
        <p class="max-w-md text-[15px] text-text-inverse/70">
          Explora tiendas de tu colonia, compara precios y contacta directo por
          WhatsApp. Apoya al comercio local.
        </p>

        <form action="/marketplace" method="get" class="flex max-w-lg gap-2">
          <div class="flex flex-1 items-center gap-2 rounded-full bg-surface-card px-4 py-3">
            <Icon name="lucide:search" class="text-text-muted" width={18} height={18} />
            <input
              type="search"
              name="q"
              placeholder="Busca productos, negocios o categorías…"
              class="w-full bg-transparent text-sm text-text-primary outline-none placeholder:text-text-muted"
            />
          </div>
          <Button type="submit" variant="primary" size="lg">Buscar</Button>
        </form>

        <div class="flex gap-8 pt-2">
          {stats.map((s) => (
            <div>
              <div class="font-data text-2xl font-semibold">{s.value}</div>
              <div class="text-xs text-text-inverse/60">{s.label}</div>
            </div>
          ))}
        </div>
      </div>

      <div class="relative hidden min-h-[320px] bg-accent-soft md:block">
        <div
          class="absolute inset-0 bg-cover bg-center"
          style="background-image:url('https://images.unsplash.com/photo-1556910103-1c02745aae4d?auto=format&fit=crop&w=900&q=70')"
        >
        </div>
        <div class="absolute inset-0 bg-gradient-to-l from-transparent to-surface-inverse/30"></div>
      </div>
    </section>

    {/* Categories */}
    <section class="mt-8">
      <div class="flex flex-wrap gap-2">
        {categories.map((c) => (
          <a
            href={`/marketplace?q=${c.q}`}
            class="flex items-center gap-2 rounded-full border border-border bg-surface-card px-4 py-2 text-sm font-medium text-text-secondary transition-colors hover:border-accent hover:text-text-primary"
          >
            <Icon name={c.icon} class="text-accent" width={16} height={16} />
            {c.label}
          </a>
        ))}
      </div>
    </section>

    {/* Featured businesses */}
    <section class="mt-12">
      <div class="mb-4 flex items-center justify-between">
        <h2 class="font-heading text-xl font-semibold">Negocios destacados</h2>
        <a href="/marketplace" class="text-sm font-medium text-accent hover:underline">
          Ver todos
        </a>
      </div>

      {businesses.length > 0 ? (
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {businesses.map((b) => (
            <BusinessCard
              name={b.name}
              type={humanize(b.business_type)}
              neighborhood={b.neighborhood ?? b.city}
              tags={[
                b.pickup_available ? "Recoge en tienda" : null,
                b.delivery_available ? "Envío" : null,
              ].filter(Boolean) as string[]}
              href={`/business/${b.slug}`}
            />
          ))}
        </div>
      ) : (
        <div class="rounded-2xl border border-dashed border-border bg-surface-card/50 p-10 text-center">
          <p class="text-sm text-text-secondary">
            Aún no hay negocios publicados. ¿Tienes uno?
          </p>
          <Button variant="primary" size="sm" href="/register" class="mt-4">
            Registra tu negocio
          </Button>
        </div>
      )}
    </section>

    {/* Handmade / latest products */}
    <section class="mt-12">
      <div class="mb-4 flex items-center justify-between">
        <h2 class="font-heading text-xl font-semibold">Hecho a mano</h2>
        <a href="/marketplace?q=handmade" class="text-sm font-medium text-accent hover:underline">
          Ver más
        </a>
      </div>

      {products.length > 0 ? (
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {products.map((p) => (
            <ProductCard
              name={p.name}
              meta={`${p.business_name}`}
              price={p.price}
              currency={p.currency}
              stockStatus={p.public_stock_status}
              href={`/business/${p.business_slug}`}
            />
          ))}
        </div>
      ) : (
        <div class="rounded-2xl border border-dashed border-border bg-surface-card/50 p-10 text-center text-sm text-text-secondary">
          Pronto verás productos de negocios locales aquí.
        </div>
      )}
    </section>

    {/* Map preview */}
    <section class="mt-12 overflow-hidden rounded-2xl border border-border bg-surface-card">
      <div class="grid items-center gap-6 p-8 md:grid-cols-[1fr_1.2fr]">
        <div class="flex flex-col gap-4">
          <h2 class="font-heading text-2xl font-semibold">Explora en el mapa</h2>
          <p class="text-sm text-text-secondary">
            Encuentra negocios y productos cerca de tu ubicación. Filtra por
            distancia, disponibilidad y tipo de tienda.
          </p>
          <Button variant="primary" href="/marketplace?map=1" icon="lucide:map" class="self-start">
            Abrir el mapa
          </Button>
        </div>
        <div class="relative h-56 overflow-hidden rounded-xl bg-surface-secondary">
          <Icon
            name="lucide:map-pinned"
            class="absolute inset-0 m-auto text-accent/30"
            width={64}
            height={64}
          />
        </div>
      </div>
    </section>

    {/* CTA */}
    <section class="mt-12 mb-4 overflow-hidden rounded-2xl bg-accent text-text-inverse">
      <div class="grid gap-6 p-8 sm:p-12 md:grid-cols-[1.3fr_1fr] md:items-center">
        <div class="flex flex-col gap-4">
          <h2 class="font-heading text-2xl font-semibold sm:text-3xl">
            ¿Tienes un negocio local? Súmate gratis.
          </h2>
          <p class="max-w-md text-sm text-text-inverse/80">
            Publica tu catálogo, controla tu inventario con código de barras y
            recibe clientes de tu zona. Sin comisiones por venta.
          </p>
          <Button variant="inverse" href="/register" class="self-start">
            Registrar mi negocio
          </Button>
        </div>
        <ul class="flex flex-col gap-3">
          {[
            "Tienda pública con tu catálogo",
            "Inventario y escáner de código de barras",
            "Analítica ABC, Pareto y punto de reorden",
            "Contacto directo por WhatsApp",
          ].map((item) => (
            <li class="flex items-center gap-3 text-sm text-text-inverse/90">
              <Icon name="lucide:check" class="shrink-0 text-text-inverse" width={18} height={18} />
              {item}
            </li>
          ))}
        </ul>
      </div>
    </section>
  </div>
</PublicLayout>
