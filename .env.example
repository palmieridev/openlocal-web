# Copy to .env.local and fill in. Do not commit real secrets.

# Clerk — get keys from the Clerk dashboard for the "Openlocal API" app.
PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# Clerk hosted-flow routing
PUBLIC_CLERK_SIGN_IN_URL=/login
PUBLIC_CLERK_SIGN_UP_URL=/register
PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/onboarding

# Openlocal API base URL.
# Local:  http://localhost:8080
# Tunnel: https://grandma-renewed-clunky.ngrok-free.dev
PUBLIC_API_BASE_URL=http://localhost:8080
